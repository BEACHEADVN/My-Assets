- name: TÌM VÀ SỬA KEY
      run: |
          echo "•••TÌM SIZE GỐC CỦA KERNELSU-NEXT"
          cd kernel/Ayaka
          FILES=$(grep -rl "0x3e6" .)
          if [ -n "$FILES" ]; then
          echo "[✔] Tìm thấy 0x3e6 trong các file:"
          echo "$FILES"
          
          # 2. Thực hiện sửa 0x3e6 thành 0x389
          echo "--- Đang tiến hành sửa thành 0x3e6 ---"
          echo "$FILES" | xargs sed -i 's/0x3e6/0x389/g'
          
          # 3. Xác nhận lại kết quả
          echo "=== Kết quả sau khi sửa ==="
          grep -rn "0x389" .
          else
          echo "[❌] Không tìm thấy 0x381 để sửa (có thể đã là 0x389 rồi)"
          echo "Kiểm tra hiện tại:"
          grep -rn "0x389" .
          fi
          echo "•••TÌM HASH GỐC CỦA KERNELSU-NEXT"
          FILES=$(grep -rl "79e590113c4c4c0c222978e413a5faa801666957b1212a328e46c00c69821bf7" .)
          if [ -n "$FILES" ]; then
          echo "[✔] Tìm thấy 79e590113c4c4c0c222978e413a5faa801666957b1212a328e46c00c69821bf7 trong các file:"
          echo "$FILES"
          
          # 2. Thực hiện sửa 79e590113c4c4c0c222978e413a5faa801666957b1212a328e46c00c69821bf7 thành e8940bdb41a8aa33d4caabd79ede0ece332f2a1eacd324c433728ef66c8170c8
          echo "--- Đang tiến hành sửa thành e8940bdb41a8aa33d4caabd79ede0ece332f2a1eacd324c433728ef66c8170c8 ---"
          echo "$FILES" | xargs sed -i 's/79e590113c4c4c0c222978e413a5faa801666957b1212a328e46c00c69821bf7/e8940bdb41a8aa33d4caabd79ede0ece332f2a1eacd324c433728ef66c8170c8/g'
          
          # 3. Xác nhận lại kết quả
          echo "=== Kết quả sau khi sửa ==="
          grep -rn "e8940bdb41a8aa33d4caabd79ede0ece332f2a1eacd324c433728ef66c8170c8" .
          else
          echo "[❌] Không tìm thấy 52d52d8c8bfbe53dc2b6ff1c613184e2c03013e090fe8905d8e3d5dc2658c2e4 để sửa (có thể đã là 0x389 rồi)"
          echo "Kiểm tra hiện tại:"
          grep -rn "52d52d8c8bfbe53dc2b6ff1c613184e2c03013e090fe8905d8e3d5dc2658c2e4" .
          fi
          echo "TÌM KBUILD"
          cat $(find . -type f -name "Kbuild")
